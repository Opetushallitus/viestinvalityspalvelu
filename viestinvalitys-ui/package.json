{
  "name": "viestinvalitys-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "webpack --mode production --config webpack.config.js",
    "start": "webpack serve --mode development --config webpack.config.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src",
    "format:check": "prettier --check src",
    "create-self-signed-dev-certs": "mkdir -p certificates && openssl req -x509 -newkey rsa:4096 -keyout ./certificates/localhost-key.pem -out ./certificates/localhost.pem -sha256 -days 365 -nodes -subj '/C=XX/ST=StateName/L=CityName/O=CompanyName/OU=CompanySectionName/CN=CommonNameOrHostname'"
  },
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.4",
    "@mui/material": "^6.1.4",
    "@mui/x-data-grid": "^7.20.0",
    "@mui/x-date-pickers": "^7.20.0",
    "@mui/x-tree-view": "^7.20.0",
    "@opetushallitus/oph-design-system": "github:opetushallitus/oph-design-system#v0.2.0",
    "@tanstack/react-query": "^5.59.15",
    "@tanstack/react-query-devtools": "^5.59.15",
    "dompurify": "^3.2.4",
    "i18next": "^23.16.4",
    "moment": "^2.30.1",
    "moment-timezone": "^0.5.46",
    "react": "^18",
    "react-dom": "^18",
    "react-i18next": "^15.1.0",
    "react-router-dom": "^6.27.0",
    "use-debounce": "^10.0.4"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "css-loader": "^7.1.2",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "html-webpack-plugin": "^5.6.3",
    "http-proxy-middleware": "^3.0.3",
    "prettier": "^3.3.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  },
  "type": "commonjs"
}
